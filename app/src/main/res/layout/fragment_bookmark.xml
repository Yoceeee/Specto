<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_color">

    <TextView
        android:id="@+id/mainTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mentett tartalmak"
        android:textColor="@color/bookmark_Title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"
        android:layout_marginStart="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false"

        app:layout_constraintTop_toBottomOf="@id/mainTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:paddingBottom="50dp">

            <TextView
                android:id="@+id/tvMoviesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filmek"
                android:textColor="@color/bookmark_type"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
            android:id="@+id/btnOpenMoviesGrid"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/cardview"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="30dp"
            app:tint="@color/bookmark_fullButton"
            app:layout_constraintBottom_toBottomOf="@+id/tvMoviesTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvMoviesTitle" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/moviesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/background_content_group"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@+id/tvMoviesTitle">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/savedMovies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvEmptyMovies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nincs mentett film"
                    android:textColor="@color/bookmark_noSavedCont"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tvSeriesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sorozatok"
                android:textColor="@color/bookmark_type"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="30dp"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/moviesContainer" />

            <ImageButton
                android:id="@+id/btnOpenSeriesGrid"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/cardview"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="30dp"
                app:tint="@color/bookmark_fullButton"
                app:layout_constraintBottom_toBottomOf="@+id/tvSeriesTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvSeriesTitle" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/seriesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/background_content_group"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@+id/tvSeriesTitle">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/savedSeries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvEmptySeries"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nincs mentett sorozat"
                    android:textColor="@color/bookmark_noSavedCont"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>