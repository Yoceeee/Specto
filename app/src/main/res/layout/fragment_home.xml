<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_color"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="90dp">
        <TextView
        android:id="@+id/greeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="55dp"
        android:text="Hello"
        android:textColor="#B3FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/userName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:text="User"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintBaseline_toBaselineOf="@id/greeting"
            app:layout_constraintEnd_toStartOf="@+id/userIcon"
            app:layout_constraintStart_toEndOf="@+id/greeting" />

        <TextView
            android:id="@+id/subTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Jó szórakozást!"
            android:textColor="#80FFFFFF"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="@+id/greeting"
            app:layout_constraintTop_toBottomOf="@+id/greeting" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/userIcon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="24dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@+id/subTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/greeting"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:srcCompat="@drawable/user_icon"
            tools:background="#444" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/heroContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@+id/subTitle">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="440dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/heroImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        tools:src="@tools:sample/backgrounds/scenic" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="@drawable/gradient_hero_scrim"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <LinearLayout
                        android:id="@+id/buttonsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnHeroDetails"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:text="Megnézem"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textAllCaps="false"
                            app:iconTint="@color/black"
                            app:backgroundTint="@color/white"
                            app:cornerRadius="24dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:layout_marginEnd="14dp"
                            android:elevation="4dp"/>

                        <ImageButton
                            android:id="@+id/btnHeroSave"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/background_content_group"
                            android:src="@drawable/bookmark_save"
                            app:tint="@color/white"
                            android:padding="14dp"
                            android:elevation="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/heroTags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Sci-Fi • Kaland • Akció"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:shadowColor="#80000000"
                        android:shadowRadius="4"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        app:layout_constraintBottom_toTopOf="@+id/buttonsContainer"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/heroTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:layout_marginStart="24dp"
                        android:layout_marginEnd="24dp"
                        android:text="Stranger Things"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:shadowColor="#FF000000"
                        android:shadowRadius="12"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        app:layout_constraintBottom_toTopOf="@+id/heroTags"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/heroContainer"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMovies"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filmek"
                android:textColor="@color/white"
                app:strokeColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSeries"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sorozatok"
                android:textColor="@color/white"
                app:strokeColor="@color/white" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/popTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Népszerű"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toggleGroup" />

        <TextView
            android:id="@+id/popularText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="filmek"
            android:textColor="@color/white"
            android:textSize="17sp"
            app:layout_constraintStart_toEndOf="@id/popTitle"
            app:layout_constraintBaseline_toBaselineOf="@id/popTitle" />

        <TextView
            android:id="@+id/btnSeeAllPopular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:text="Összes"
            android:textColor="#FFC107"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBaselineOf="@id/popTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/popProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/recyclerViewPopularMovie"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/recyclerViewPopularMovie" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewPopularMovie"
            android:layout_width="match_parent"
            android:layout_height="285dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:minHeight="150dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@+id/popTitle"
            tools:layout_editor_absoluteX="0dp"
            tools:listitem="@layout/content_card" />

        <TextView
            android:id="@+id/newTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="Új"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/recyclerViewPopularMovie" />

        <TextView
            android:id="@+id/newText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="filmek"
            android:textColor="@color/white"
            android:textSize="17sp"
            app:layout_constraintStart_toEndOf="@id/newTitle"
            app:layout_constraintBaseline_toBaselineOf="@id/newTitle"  />


        <TextView
            android:id="@+id/btnSeeAllNew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:text="Összes"
            android:textColor="#FFC107"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBaselineOf="@id/newTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/newProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/recyclerViewNewMovie"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/recyclerViewNewMovie" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewNewMovie"
            android:layout_width="match_parent"
            android:layout_height="285dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:minHeight="150dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/newTitle"
            tools:listitem="@layout/content_card" />

        <TextView
            android:id="@+id/allTimeBestTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="Top"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/recyclerViewNewMovie" />

        <TextView
            android:id="@+id/allTimeBestText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="filmek"
            android:textColor="@color/white"
            android:textSize="17sp"
            app:layout_constraintStart_toEndOf="@id/allTimeBestTitle"
            app:layout_constraintBaseline_toBaselineOf="@id/allTimeBestTitle"  />


        <TextView
            android:id="@+id/btnSeeAllBest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:text="Összes"
            android:textColor="#FFC107"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBaselineOf="@id/allTimeBestTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/allTimeBestProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/recyclerViewAllTimeBestMovie"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/recyclerViewAllTimeBestMovie" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewAllTimeBestMovie"
            android:layout_width="match_parent"
            android:layout_height="285dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:minHeight="150dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/allTimeBestTitle"
            tools:listitem="@layout/content_card" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>