<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_color"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="26dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="Üdv újra!"
        android:textColor="@color/greetings"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBack" />

    <TextView
        android:id="@+id/textSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Jelentkezz be a folytatáshoz"
        android:textColor="@color/underGreetings"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textTitle" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputEmailLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:hint="Email cím"
        android:textColorHint="@color/hints"
        app:boxStrokeColor="@color/inputFields"
        app:boxStrokeErrorColor="@color/inputFields"
        app:cursorColor="@color/inputFields"
        app:hintTextColor="@color/inputFields"
        app:layout_constraintTop_toBottomOf="@+id/textSubtitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/inputFields" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputConfirmUsernameLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Felhasználónév"
        android:textColorHint="@color/hints"
        android:visibility="gone"
        app:boxStrokeColor="@color/inputFields"
        app:boxStrokeErrorColor="#CF6679"
        app:cursorColor="@color/inputFields"
        app:hintTextColor="@color/inputFields"
        app:layout_constraintTop_toBottomOf="@+id/inputEmailLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/inputFields" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputPasswordLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Jelszó"
        android:textColorHint="@color/hints"
        app:boxStrokeColor="@color/inputFields"
        app:boxStrokeErrorColor="#CF6679"
        app:cursorColor="@color/inputFields"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/inputFields"
        app:hintTextColor="@color/inputFields"
        app:layout_constraintTop_toBottomOf="@+id/inputConfirmUsernameLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/inputFields" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputConfirmPasswordLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Jelszó megerősítése"
        android:textColorHint="@color/hints"
        android:visibility="gone"
        app:boxStrokeColor="@color/inputFields"
        app:boxStrokeErrorColor="#CF6679"
        app:cursorColor="@color/inputFields"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/inputFields"
        app:hintTextColor="@color/inputFields"
        app:layout_constraintTop_toBottomOf="@+id/inputPasswordLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/inputFields" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAuthAction"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="Bejelentkezés"
        android:textSize="16sp"
        android:textColor="@color/signInButtonText"
        android:textStyle="bold"
        app:backgroundTint="@color/signInButton"
        app:cornerRadius="25dp"
        app:layout_constraintTop_toBottomOf="@+id/inputConfirmPasswordLayout" />
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAuthAction">

        <TextView
            android:id="@+id/textSwitchInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Még nincs fiókod?"
            android:textColor="@color/hints" />

        <TextView
            android:id="@+id/textSwitchAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Regisztráció"
            android:textColor="@color/hints"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/hints"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>