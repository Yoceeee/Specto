<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:paddingHorizontal="11dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_rounded_sheet"
        android:orientation="vertical"
        android:padding="20dp">

        <View
            android:layout_width="40dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="25dp"
            android:background="@drawable/bg_drag_handle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Rendezés beállítása"
            android:textColor="@color/detail_title"
            android:textSize="23sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/sortTopRated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <ImageView
                android:id="@+id/emptyTopRated"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/circle_icon"
                app:tint="@color/detail_title" />

            <ImageView
                android:id="@+id/checkTopRated"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/checked_circle_icon"
                android:visibility="gone"
                app:tint="@color/home_all_btn" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Legjobbra értékeltek elöl"
                android:textColor="@color/detail_title"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sortNewest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <ImageView
                android:id="@+id/emptyNewest"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/circle_icon"
                app:tint="@color/detail_title" />

            <ImageView
                android:id="@+id/checkNewest"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/checked_circle_icon"
                android:visibility="gone"
                app:tint="@color/home_all_btn" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Legújabbak elöl"
                android:textColor="@color/detail_title"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sortAlpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <ImageView
                android:id="@+id/emptyAlpha"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/circle_icon"
                app:tint="@color/detail_title" />

            <ImageView
                android:id="@+id/checkAlpha"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/checked_circle_icon"
                android:visibility="gone"
                app:tint="@color/home_all_btn" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Cím alapján (A-Z)"
                android:textColor="@color/detail_title"
                android:textSize="17sp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>